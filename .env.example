# Optional. Vercel injects its own deployment URL automatically.
# Set this after connecting a custom domain.
NEXT_PUBLIC_SITE_URL=https://example.com

# Optional. Minimal PostHog capture endpoint support.
# Leave empty to disable PostHog completely.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
