# Optional. Vercel injects its own deployment URL automatically.
# Set this after connecting a custom domain.
NEXT_PUBLIC_SITE_URL=https://example.com

# Optional. Minimal PostHog capture endpoint support.
# Leave empty to disable PostHog completely.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Optional: generates Hebrew narration for the Remotion XRP video.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Dashboard operational foundation.
# Server-only values. Do not expose these with NEXT_PUBLIC_ prefixes.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DASHBOARD_ADMIN_EMAIL=
DASHBOARD_RATE_LIMIT_HMAC_SECRET=
DASHBOARD_BASE_URL=
DASHBOARD_ALLOWED_CALLBACK_URLS=
GITHUB_REPOSITORY=haimraf/ai-source-lab
GITHUB_DEFAULT_BRANCH=main
GITHUB_READ_TOKEN=
