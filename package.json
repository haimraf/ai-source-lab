{
  "name": "ai-source-lab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run generate:sitemap",
    "build": "next build",
    "generate:sitemap": "tsx scripts/generate-claim-sitemap.ts",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:content": "vitest run lib/content-integrity.repository.test.ts",
    "video:studio": "remotion studio videos/xrp/index.ts",
    "video:still:vertical": "remotion still videos/xrp/index.ts XrpVertical artifacts/video/xrp-vertical.png --frame=300",
    "video:still:landscape": "remotion still videos/xrp/index.ts XrpLandscape artifacts/video/xrp-landscape.png --frame=300",
    "video:render": "node --strip-types videos/xrp/render.ts"
  },
  "dependencies": {
    "@fontsource-variable/heebo": "^5.2.8",
    "@remotion/bundler": "^4.0.481",
    "@remotion/cli": "^4.0.481",
    "@remotion/media": "^4.0.481",
    "@remotion/renderer": "^4.0.481",
    "@remotion/transitions": "^4.0.481",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.110.0",
    "@vercel/analytics": "latest",
    "@vercel/speed-insights": "^2.0.0",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remotion": "^4.0.481",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "supabase": "2.109.0",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
